NEXT_PUBLIC_SITE_URL=https://www.bezgrow.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: choose where Bezgrow stores the auto-generated server-only license signing keystore.
# Defaults to .bezgrow/license-signing-key.json.
BEZGROW_LICENSE_KEYSTORE_DIR=
BEZGROW_LICENSE_KEYSTORE_PATH=

# Legacy/emergency only. Normal admins should not set these manually.
BEZGROW_LICENSE_PRIVATE_KEY=
NEXT_PUBLIC_BEZGROW_LICENSE_PUBLIC_KEY=

# Optional for desktop builds. Defaults to NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_DESKTOP_API_ORIGIN=https://www.bezgrow.com
